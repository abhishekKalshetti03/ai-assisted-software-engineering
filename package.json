{
  "name": "express-typescript-starter",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "test": "jest --runInBand",
    "coverage": "jest --runInBand --coverage",
    "coverage:report": "jest --runInBand --coverage --coverageReporters=text-summary",
    "prepare": "husky install"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "tsc --noEmit"
    ]
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.1",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "morgan": "^1.10.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.10.1",
    "@types/supertest": "^6.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "nyc": "^18.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
